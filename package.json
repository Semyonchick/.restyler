{
  "name": "restyler",
  "version": "1.3.0",
  "description": "Reusable Webpack-based frontend build system for PHP and Bitrix projects",
  "private": true,
  "main": "index.js",
  "packageManager": "npm@11",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11 <12"
  },
  "scripts": {
    "start": "npm run watch",
    "dev": "webpack --mode development",
    "cert": "node scripts/create-local-certificate.js",
    "watch": "webpack-dev-server --mode development --open --https --key .cert/localhost-key.pem --cert .cert/localhost.pem",
    "build": "webpack --mode production",
    "audit": "npm audit --audit-level=moderate"
  },
  "browserslist": [
    "> 0.5%",
    "last 4 versions",
    "IE 9"
  ],
  "babel": {
    "presets": [
      "@babel/preset-env"
    ]
  },
  "dependencies": {
    "axios": "^1.11.0",
    "babel-polyfill": "^6.26.0",
    "bulma": "^0.7.5",
    "bulma-extensions": "^3.0.0",
    "swiper": "^12.1.2",
    "vue": "^2.7.16",
    "vue-axios": "^2.1.5"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "autoprefixer": "^9.8.8",
    "babel-loader": "^8.4.1",
    "clean-webpack-plugin": "^0.1.19",
    "copy-webpack-plugin": "^5.1.2",
    "css-loader": "^3.6.0",
    "cssnano": "^4.1.11",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^3.2.0",
    "image-webpack-loader": "^8.1.0",
    "lodash": "^4.17.21",
    "mini-css-extract-plugin": "^0.12.0",
    "modernizr": "3.12.0",
    "modernizr-loader": "^1.0.1",
    "portfinder-sync": "^0.0.2",
    "postcss-loader": "^3.0.0",
    "pug": "^3.0.3",
    "pug-html-loader": "^1.1.5",
    "pug-loader": "^2.4.0",
    "resolve-url-loader": "^3.1.5",
    "sass": "^1.89.2",
    "sass-loader": "^10.5.2",
    "simple-git": "^1.132.0",
    "style-loader": "^1.3.0",
    "svg-fill-loader": "0.0.8",
    "svg-sprite-loader": "^3.9.2",
    "uglifyjs-webpack-plugin": "^2.2.0",
    "vue-loader": "^15.11.1",
    "vue-template-compiler": "2.7.16",
    "webpack": "^4.47.0",
    "webpack-bundle-analyzer": "^3.9.0",
    "webpack-cli": "^3.3.12",
    "webpack-dev-server": "^3.11.3"
  },
  "overrides": {
    "y18n": "^5.0.8"
  },
  "keywords": [
    "webpack",
    "bitrix",
    "php",
    "vue"
  ],
  "author": "Semyonchick",
  "license": "ISC"
}
