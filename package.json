{
  "name": "restyler",
  "version": "1.4.0",
  "description": "Reusable Webpack-based frontend build system for PHP and Bitrix projects",
  "private": true,
  "main": "index.js",
  "packageManager": "npm@11",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11 <12"
  },
  "scripts": {
    "start": "npm run watch",
    "dev": "webpack --mode development",
    "cert": "node scripts/create-local-certificate.js",
    "watch": "node scripts/check-local-certificate.js && webpack serve --mode development --open",
    "build": "webpack --mode production",
    "audit": "npm audit --audit-level=moderate"
  },
  "browserslist": [
    "> 0.5%",
    "last 4 versions",
    "IE 9"
  ],
  "babel": {
    "presets": [
      "@babel/preset-env"
    ]
  },
  "dependencies": {
    "axios": "^1.11.0",
    "bulma": "^1.0.4",
    "core-js": "^3.45.1",
    "regenerator-runtime": "^0.14.1",
    "swiper": "^14.0.5",
    "vue": "^2.7.16",
    "vue-axios": "^2.1.5"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "autoprefixer": "^10.4.21",
    "babel-loader": "^10.1.1",
    "css-loader": "^7.1.4",
    "cssnano": "^8.0.2",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^5.6.7",
    "lodash": "^4.17.21",
    "mini-css-extract-plugin": "^2.10.2",
    "portfinder-sync": "^0.0.2",
    "postcss": "^8.5.6",
    "postcss-loader": "^8.2.1",
    "pug": "^3.0.4",
    "pug-html-loader": "^1.1.7",
    "resolve-url-loader": "^5.0.0",
    "sass": "^1.92.1",
    "sass-loader": "^17.0.0",
    "simple-git": "^3.28.0",
    "svg-spritemap-webpack-plugin": "^5.1.4",
    "vue-loader": "^15.11.1",
    "vue-template-compiler": "2.7.16",
    "webpack": "^5.108.4",
    "webpack-bundle-analyzer": "^5.3.1",
    "webpack-cli": "^7.2.1",
    "webpack-dev-server": "^6.0.0"
  },
  "overrides": {
    "debug": "^4.4.1",
    "domelementtype@1.3.0": "1.3.1",
    "ini": "^1.3.8",
    "is-accessor-descriptor@0.1.6": "0.1.7",
    "is-accessor-descriptor@1.0.0": "1.0.1",
    "is-data-descriptor@0.1.4": "0.1.5",
    "is-data-descriptor@1.0.0": "1.0.1",
    "tar@6.2.1": "6.2.2",
    "y18n": "^5.0.8"
  },
  "keywords": [
    "webpack",
    "bitrix",
    "php",
    "vue"
  ],
  "author": "Semyonchick",
  "license": "ISC"
}
