{
  "name": "restyler",
  "version": "1.3.1",
  "description": "Reusable Webpack-based frontend build system for PHP and Bitrix projects",
  "private": true,
  "main": "index.js",
  "packageManager": "npm@11",
  "engines": {"node": ">=24 <25", "npm": ">=11 <12"},
  "scripts": {
    "start": "npm run watch",
    "dev": "webpack --mode development",
    "cert": "node scripts/create-local-certificate.js",
    "watch": "node scripts/check-local-certificate.js && webpack serve --mode development --open",
    "build": "webpack --mode production",
    "audit": "npm audit --audit-level=moderate"
  },
  "browserslist": ["> 0.5%", "last 4 versions", "IE 9"],
  "babel": {"presets": ["@babel/preset-env"]},
  "dependencies": {
    "axios": "^1.11.0",
    "bulma": "^0.7.5",
    "bulma-extensions": "^3.0.0",
    "core-js": "^3.45.1",
    "regenerator-runtime": "^0.14.1",
    "swiper": "^12.1.2",
    "vue": "^2.7.16",
    "vue-axios": "^2.1.5"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.3",
    "autoprefixer": "^10.4.21",
    "babel-loader": "^8.4.1",
    "css-loader": "^5.2.7",
    "cssnano": "^5.1.15",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^4.5.2",
    "lodash": "^4.17.21",
    "mini-css-extract-plugin": "^1.6.2",
    "portfinder-sync": "^0.0.2",
    "postcss": "^8.5.6",
    "postcss-loader": "^4.3.0",
    "pug": "^3.0.4",
    "pug-html-loader": "^1.1.7",
    "resolve-url-loader": "^5.0.0",
    "sass": "^1.92.1",
    "sass-loader": "^10.5.2",
    "simple-git": "^3.28.0",
    "svg-sprite-loader": "^6.0.11",
    "vue-loader": "^15.11.1",
    "vue-template-compiler": "2.7.16",
    "webpack": "^4.47.0",
    "webpack-bundle-analyzer": "^4.10.2",
    "webpack-cli": "^4.10.0",
    "webpack-dev-server": "^4.15.2"
  },
  "overrides": {
    "debug": "^4.4.1",
    "domelementtype@1.3.0": "1.3.1",
    "ini": "^1.3.8",
    "is-accessor-descriptor@0.1.6": "0.1.7",
    "is-accessor-descriptor@1.0.0": "1.0.1",
    "is-data-descriptor@0.1.4": "0.1.5",
    "is-data-descriptor@1.0.0": "1.0.1",
    "tar@6.2.1": "6.2.2",
    "y18n": "^5.0.8"
  },
  "keywords": ["webpack", "bitrix", "php", "vue"],
  "author": "Semyonchick",
  "license": "ISC"
}
