{
  "name": "restyler",
  "version": "1.3.0",
  "description": "Reusable Webpack-based frontend build system for PHP and Bitrix projects",
  "private": true,
  "main": "index.js",
  "packageManager": "npm@11",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11 <12"
  },
  "scripts": {
    "start": "npm run watch",
    "dev": "webpack --mode development",
    "watch": "webpack-dev-server --mode development --open",
    "build": "webpack --mode production",
    "audit": "npm audit"
  },
  "browserslist": ["> 0.5%", "last 4 versions", "IE 9"],
  "babel": {
    "presets": ["@babel/preset-env"]
  },
  "dependencies": {
    "axios": "^1.11.0",
    "babel-polyfill": "^6.26.0",
    "bulma": "^0.7.5",
    "bulma-extensions": "^3.0.0",
    "modernizr": "3.12.0",
    "pug": "^3.0.3",
    "pug-html-loader": "^1.1.5",
    "pug-loader": "^2.4.0",
    "swiper": "^12.1.2",
    "vue": "^2.7.16",
    "vue-axios": "^2.1.5"
  },
  "overrides": {
    "y18n": "^5.0.8"
  },
  "keywords": ["webpack", "bitrix", "php", "vue"],
  "author": "Semyonchick",
  "license": "ISC"
}